@model List<DataBridge.Models.ClienteAntigo>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Clientes</h2>
    <div class="d-flex gap-2">
        <a asp-action="New" class="btn btn-primary">+ Novo Registro</a>
        <a asp-action="IntegratedFiles" class="btn btn-outline-secondary">📂 Arquivos Transferidos</a>
    </div>
</div>

<!-- Filtro de pesquisa -->
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="filtro" value="@ViewBag.Filtro"
               class="form-control" placeholder="Pesquisar por nome..." />
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.Filtro as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
        }
    </div>
</form>

<!-- Tabela de clientes -->
@if (!Model.Any())
{
    <div class="alert alert-info">Nenhum cliente encontrado.</div>
}
else
{
    <table class="table table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Telefone</th>
                <th>Cidade</th>
                <th>Estado</th>
                <th>Cadastro</th>
                <th>Ativo</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cliente in Model)
            {
                <tr>
                    <td>@cliente.NomeCompleto</td>
                    <td>@(cliente.Telefone ?? "—")</td>
                    <td>@(cliente.Cidade ?? "—")</td>
                    <td>@(cliente.Estado ?? "—")</td>
                    <td>@cliente.DataCadastro.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (cliente.Ativo)
                        {
                            <span class="badge bg-success">Ativo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inativo</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Edit" asp-route-id="@cliente.Id"
                               class="btn btn-sm btn-outline-primary">Editar</a>
                            <a asp-action="Integrated" asp-route-id="@cliente.Id"
                               class="btn btn-sm btn-success">Integrar</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}