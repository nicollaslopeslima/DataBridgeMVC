@model DataBridge.Models.ClienteAntigo

@{
    ViewData["Title"] = "Novo Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Novo Cliente</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-8">
        <form asp-action="New" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="NomeCompleto" class="form-label">Nome Completo *</label>
                <input asp-for="NomeCompleto" class="form-control" placeholder="Digite o nome completo" />
                <span asp-validation-for="NomeCompleto" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Telefone" class="form-label">Telefone</label>
                <input asp-for="Telefone" class="form-control" maxlength="11" placeholder="(00) 00000-0000" />
            </div>

            <div class="mb-3">
                <label asp-for="CEP" class="form-label">CEP</label>
                <input asp-for="CEP" class="form-control" placeholder="00000-000"
                       id="cep" maxlength="9" />
            </div>

            <div class="mb-3">
                <label asp-for="Endereco" class="form-label">Endereço</label>
                <input asp-for="Endereco" class="form-control" id="endereco" />
            </div>

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Cidade" class="form-label">Cidade</label>
                    <input asp-for="Cidade" class="form-control" id="cidade" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Estado" class="form-label">Estado</label>
                    <input asp-for="Estado" class="form-control" id="estado" maxlength="2" />
                </div>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="Ativo" class="form-check-input" type="checkbox" checked />
                    <label asp-for="Ativo" class="form-check-label">Ativo</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Salvar</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/cliente/new.js"></script>
}
